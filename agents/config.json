{
  "version": "1.0.0",
  "name": "Development Agent Ecosystem",
  "description": "개발의 모든 영역(A-Z)을 커버하는 전문 에이전트 생태계",

  "categories": {
    "database": {
      "name": "Database & Data",
      "description": "데이터베이스 설계, 쿼리 최적화, 마이그레이션",
      "agents": ["db-architect", "db-query", "db-migration", "db-indexing", "db-scaling", "db-nosql"]
    },
    "api": {
      "name": "API Development",
      "description": "API 설계, 구현, 검증",
      "agents": ["api-designer", "api-implementer", "api-validator", "api-gateway", "api-versioning"]
    },
    "frontend": {
      "name": "Frontend & UI",
      "description": "UI 컴포넌트, 상태관리, 접근성, Hotwire Native",
      "agents": ["ui-component", "ui-state", "ui-a11y", "ui-styling", "ui-performance", "hotwire-native"]
    },
    "backend": {
      "name": "Backend & Services",
      "description": "비즈니스 로직, 인증, 통합",
      "agents": ["service-logic", "auth-architect", "integration-api", "service-resilience", "service-caching", "realtime-services", "background-jobs"]
    },
    "search-data": {
      "name": "Search & Data Processing",
      "description": "검색 엔진, 메시지 큐, 데이터 파이프라인",
      "agents": ["search-engine", "vector-search", "message-queue", "data-pipeline"]
    },
    "infrastructure": {
      "name": "Infrastructure & DevOps",
      "description": "IaC, 컨테이너, CI/CD, 배포",
      "agents": ["iac-architect", "container-k8s", "docker-specialist", "serverless-architect", "cicd-pipeline", "deployment-strategy", "cloud-cost"]
    },
    "testing": {
      "name": "Testing",
      "description": "단위/통합/E2E/성능/보안 테스트",
      "agents": ["test-unit", "test-integration", "test-e2e", "test-performance", "test-security", "test-contract", "test-mutation", "test-visual"]
    },
    "security": {
      "name": "Security",
      "description": "보안 감사, 위협 모델링, 컴플라이언스",
      "agents": ["security-audit", "security-threat", "security-secrets", "security-compliance", "security-sca", "security-penetration"]
    },
    "ml-ai": {
      "name": "ML/AI",
      "description": "모델 훈련, 추론, MLOps",
      "agents": ["ml-training", "ml-inference", "ml-deployment", "ml-monitoring", "ml-data"]
    },
    "mobile": {
      "name": "Mobile",
      "description": "크로스플랫폼, 네이티브, 모바일 테스트",
      "agents": ["mobile-crossplatform", "mobile-native", "mobile-testing"]
    },
    "observability": {
      "name": "Observability",
      "description": "메트릭, 로깅, 트레이싱, 인시던트",
      "agents": ["metrics-architect", "logging-architect", "tracing-architect", "incident-response"]
    },
    "documentation": {
      "name": "Documentation",
      "description": "기술 문서, API 스펙, 아키텍처 문서",
      "agents": ["doc-technical", "doc-api-spec", "doc-architecture", "doc-changelog"]
    },
    "git-collab": {
      "name": "Version Control & Collaboration",
      "description": "Git 워크플로우, 코드 리뷰",
      "agents": ["git-workflow", "code-review"]
    },
    "architecture": {
      "name": "Architecture",
      "description": "시스템/마이크로서비스/이벤트/데이터 아키텍처",
      "agents": ["arch-system", "arch-microservices", "arch-event-driven", "arch-data"]
    }
  },

  "orchestration": {
    "defaultWaves": {
      "design": ["arch-system", "db-architect", "api-designer", "ui-component"],
      "implement": ["db-migration", "api-implementer", "service-logic", "ui-state"],
      "quality": ["test-unit", "test-integration", "security-audit", "doc-api-spec"],
      "deploy": ["cicd-pipeline", "deployment-strategy"]
    },
    "maxParallelAgents": 5,
    "timeoutSeconds": 300
  },

  "tools": {
    "readonly": ["Read", "Glob", "Grep", "WebSearch", "WebFetch"],
    "write": ["Write", "Edit", "Bash"],
    "restricted": ["NotebookEdit", "KillShell"]
  },

  "metadata": {
    "created": "2026-01-16",
    "totalAgents": 56,
    "totalCategories": 14
  }
}
